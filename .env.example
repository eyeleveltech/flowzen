# Database (local dev — running the API outside Docker)
DATABASE_URL="postgresql://postgres:your_local_db_password@localhost:5432/flowzen?schema=public"

# Docker Compose (REQUIRED — compose fails to start if these are unset).
# docker-compose.yml builds DATABASE_URL from these for the containerised API.
POSTGRES_USER="elitepm"
POSTGRES_PASSWORD=""          # REQUIRED. Must match the password the postgres volume
                              # was initialised with, or the API cannot connect.
POSTGRES_DB="elitepm"

# JWT — REQUIRED. Compose fails to start if unset (no fallback: a default here would
# be a publicly-known signing key that anyone could use to forge admin tokens).
JWT_SECRET="generate_a_very_long_secure_random_string"
JWT_EXPIRES_IN="7d"

# Server
API_PORT=4000
API_URL="http://localhost:4000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# LinkedIn Intelligence (Module A) + AI Outreach (Module B)
APIFY_TOKEN=""
OPENAI_API_KEY=""
APIFY_LINKEDIN_ACTOR=""        # e.g. "dev_fusion/linkedin-profile-scraper" — your Apify actor slug
APIFY_LINKEDIN_INPUT_KEY="" # optional: profileUrls (default) | urls | startUrls

SMTP_HOST=""
SMTP_PORT=
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
