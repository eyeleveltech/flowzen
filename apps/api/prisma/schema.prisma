generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  ONHOLD
  CHURNED
  PROJECT_COMPLETED
}

enum ProjectType {
  RETAINER
  ONE_TIME
  EVENT
  INTERNAL
}

enum ReportingCadence {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  NONE
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  X_TWITTER
  TIKTOK
  YOUTUBE
  GOOGLE_ADS
  WEBSITE
  MOBILE_APP
  E_COMMERCE
  CROSS_PLATFORM
  OTHER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  APPROVED
  BLOCKED
  ON_HOLD
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  DESIGN
  CONTENT
  VIDEO
  DIGITAL_MARKETING
  SOCIAL_MEDIA
  DEVELOPMENT
  STRATEGY
  BUSINESS
  OTHER
}

enum NoteType {
  INTERNAL
  MEETING
}

enum ActivityEntityType {
  CLIENT
  PROJECT
  TASK
  TEAM
  ORGANIZATION
  LEAD
}

enum LeadSource {
  EXCEL
  MANUAL
  API
  REFERRAL
  INBOUND
  LINKEDIN
  INSTAGRAM
  WHATSAPP
  OTHER
  OUTBOUND
  SOCIAL_MEDIA
  EVENT
  COLD_CALL
  EXISTING_CLIENT
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

enum ContactRole {
  DECISION_MAKER
  INFLUENCER
  GATEKEEPER
  CHAMPION
  CC_ONLY
}

enum RenewalStatus {
  UPCOMING
  IN_DISCUSSION
  RENEWED
  AT_RISK
  CHURNED
}

enum LeadStage {
  NEW_LEAD
  OUTREACH
  MEETING
  PROPOSAL
  NEGOTIATION
  CONTRACT
  ACTIVE_RETAINER
  ACTIVE_PROJECT
  PROJECT_COMPLETED
  CHURNED
  ON_HOLD
}

enum ContractType {
  RETAINER
  ONE_TIME
}

enum HealthStatus {
  GREEN
  AMBER
  RED
}

enum LostReason {
  BUDGET
  COMPETITOR
  NO_BUDGET
  TIMING
  UNRESPONSIVE
  SCOPE_MISMATCH
  INTERNAL_CHANGE
  OTHER
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_REVIEW
  DEADLINE_APPROACHING
  TASK_OVERDUE
  COMMENT_ADDED
  PROJECT_STATUS_CHANGED
  CLIENT_ADDED
  MENTION
  FOLLOW_UP_DUE
  FOLLOW_UP_OVERDUE
  STALE_LEAD
  PAYMENT_DUE
  PAYMENT_OVERDUE
  RENEWAL_DUE
  REACTIVATION_DUE
  DAILY_DIGEST
}

// ──────────────────────────────────────────────
// MODELS
// ──────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  website   String?
  industry  String?
  companySize String?
  phone     String?
  address   String?
  description String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  apiKeys ApiKey[]
  clients Client[]
  leads   Lead[]
  modules OrganizationModule[]
  quotes  QuoteDocument[]
  templates ProjectTemplate[]
  auditLogs     AuditLog[]      @relation("OrganizationAuditLogs")
  // Revenue
  invoiceDrafts InvoiceDraft[]
  contracts     Contract[]
  payments      Payment[]
  subscriptions Subscription[]
  expenses      Expense[]

  @@map("organizations")
}

// Which feature modules (e.g. CRM, PM) an organization has enabled.
model OrganizationModule {
  id             String   @id @default(cuid())
  organizationId String
  key            String   // 'CRM' | 'PM' (plain string so new modules need no enum change)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("organization_modules")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  name           String
  avatar         String?
  role           UserRole @default(TEAM_MEMBER)
  designation    String?
  phone          String?
  joiningDate    DateTime @default(now())
  status           UserStatus @default(PENDING)
  resetToken       String?  @unique
  resetTokenExpiry DateTime?
  lastActivityReadAt DateTime?
  settings         Json     @default("{}") // per-user prefs (e.g. notifications)
  organizationId   String
  teamId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team?           @relation("TeamMembers", fields: [teamId], references: [id])
  ownedProjects  Project[]       @relation("ProjectOwner")
  assignedTasks  Task[]          @relation("TaskAssignee")
  assignedTasksMulti Task[]      @relation("TaskAssignees")
  assignedTasksBy Task[]         @relation("TaskAssigner")
  reviewedTasks  Task[]          @relation("TaskReviewer")
  apiKeys        ApiKey[]
  comments       Comment[]
  activities     Activity[]
  notifications  Notification[]
  notes          Note[]
  projectMembers ProjectMember[]
  managedTeams   TeamManager[]
  managedClients Client[]        @relation("ClientAccountManager")
  createdWorkflows WorkflowRule[] @relation("WorkflowCreator")
  assignedLeads  Lead[]          @relation("LeadAssignee")
  stageChanges   StageHistory[]  @relation("StageChanger")
  quotesAsSalesperson QuoteDocument[] @relation("QuoteSalesperson")
  auditLogs           AuditLog[]      @relation("UserAuditLogs")

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("users")
}

model ApiKey {
  id             String       @id @default(cuid())
  key            String       @unique
  name           String       
  userId         String       
  organizationId String       
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([key])
  @@map("api_keys")
}

model Client {
  id             String       @id @default(cuid())
  name           String
  company        String?
  industry       String?
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  contractValue  Float?
  startDate      DateTime?
  status         ClientStatus @default(PROSPECT)
  engagementType String?
  website        String?
  city           String?
  state          String?
  scope          String?
  assetLinks     String?
  accountManagerId String?
  organizationId String
  // Billing details used to auto-fill quotations / proforma invoices
  billingAddress String?      @db.Text
  gstNumber      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  notes        Note[]
  activities   Activity[]    @relation("ClientActivities")
  contacts     ClientContact[]
  accountManager User?       @relation("ClientAccountManager", fields: [accountManagerId], references: [id])
  lead         Lead?
  tasks        Task[]        @relation("ClientTasks")
  quotes       QuoteDocument[]

    // Revenue
  invoiceDrafts InvoiceDraft[] @relation("ClientInvoiceDrafts")
  contracts     Contract[]     @relation("ClientContracts")
  payments      Payment[]      @relation("ClientPayments")
  subscriptions Subscription[] @relation("ClientSubscriptions")
  expenses      Expense[]      @relation("ClientExpenses")

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("clients")
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  type        ProjectType     @default(ONE_TIME)
  scope       String?
  startDate   DateTime?
  endDate     DateTime?
  priority    ProjectPriority @default(MEDIUM)
  status      ProjectStatus   @default(PLANNING)
  budget      Float?
  progress    Int             @default(0)
  reportingCadence ReportingCadence @default(NONE)
  clientApprovalRequired Boolean @default(false)
  tags        String[]
  projectNotes String?
  folderLink  String?
  clientId    String
  ownerId     String
  templateId  String?
  color       String          @default("#3B82F6")
  platform    ProjectPlatform?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  client     Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner      User             @relation("ProjectOwner", fields: [ownerId], references: [id])
  template   ProjectTemplate? @relation(fields: [templateId], references: [id])
  tasks      Task[]
  milestones Milestone[]
  activities Activity[]       @relation("ProjectActivities")
  members    ProjectMember[]
  teams      ProjectTeam[]
  comments               Comment[]
  expenses   Expense[]   @relation("ProjectExpenses")

  @@index([clientId, status])
  @@index([ownerId, status])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Team {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  managers TeamManager[]
  members  User[]        @relation("TeamMembers")
  projects ProjectTeam[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

model TeamManager {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_managers")
}

model ProjectTeam {
  id        String   @id @default(cuid())
  projectId String
  teamId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([projectId, teamId])
  @@map("project_teams")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        TaskType     @default(OTHER)
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(BACKLOG)
  dueDate     DateTime?
  assignedDate DateTime?
  order       Int          @default(0)
  projectId   String?
  leadId      String?
  clientId    String?
  assigneeId  String?
  reviewerId  String?
  assignedById String?
  parentId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completedAt DateTime?
  readAt      DateTime?
  loggedHours Float?       @default(0)
  estimatedHours Float?    @default(0)
  driveLink   String?
  isRecurring Boolean      @default(false)
  recurrenceFrequency String?

  project    Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lead       Lead?           @relation("LeadTasks", fields: [leadId], references: [id], onDelete: Cascade)
  client     Client?         @relation("ClientTasks", fields: [clientId], references: [id], onDelete: Cascade)
  assignee   User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assignees  User[]          @relation("TaskAssignees")
  assignedBy User?           @relation("TaskAssigner", fields: [assignedById], references: [id])
  reviewer   User?           @relation("TaskReviewer", fields: [reviewerId], references: [id])
  parent     Task?           @relation("SubTasks", fields: [parentId], references: [id])
  subtasks   Task[]          @relation("SubTasks")
  comments   Comment[]
  checklist  ChecklistItem[]
  activities Activity[]      @relation("TaskActivities")

  @@index([projectId, status, assigneeId])
  @@index([assigneeId, status])
  @@map("tasks")
}

model Milestone {
  id        String    @id @default(cuid())
  name      String
  dueDate   DateTime?
  completed Boolean   @default(false)
  projectId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String?
  projectId String?
  authorId  String
  mentions  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id])

  @@map("comments")
}

model ChecklistItem {
  id        String  @id @default(cuid())
  text      String
  completed Boolean @default(false)
  order     Int     @default(0)
  taskId    String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model Activity {
  id         String             @id @default(cuid())
  type       String
  message    String
  direction  String?
  entityType ActivityEntityType
  entityId   String
  metadata   Json?
  userId     String
  clientId   String?
  projectId  String?
  taskId     String?
  leadId     String?
  createdAt  DateTime           @default(now())

  user    User     @relation(fields: [userId], references: [id])
  client  Client?  @relation("ClientActivities", fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation("ProjectActivities", fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation("TaskActivities", fields: [taskId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation("LeadActivities", fields: [leadId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("activities")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  userId    String
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model Note {
  id        String   @id @default(cuid())
  content   String
  type      NoteType @default(INTERNAL)
  clientId  String?
  leadId    String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id])

  @@map("notes")
}

model ProjectTemplate {
  id          String      @id @default(cuid())
  name        String
  description String?
  type        ProjectType @default(RETAINER)
  structure   Json
  organizationId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([organizationId])
  @@map("project_templates")
}

model ClientContact {
  id          String   @id @default(cuid())
  name        String
  designation String?
  email       String?
  phone       String?
  clientId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

// ──────────────────────────────────────────────
// CRM PIPELINE
// ──────────────────────────────────────────────

model Lead {
  id                String       @id @default(cuid())
  leadId            String?      // FL-YYYYMM-XXXXXX, auto-generated on creation, never editable (unique PER ORG)
  clientId          String?      @unique
  organizationId    String
  source            LeadSource   @default(MANUAL)
  stage             LeadStage    @default(NEW_LEAD)
  priority          LeadPriority @default(MEDIUM)
  assignedToId      String?
  dealValue         Float?
  expectedCloseDate DateTime?
  expectedRevenue   Float?
  followUpDate      DateTime?
  contractType      ContractType?
  healthStatus      HealthStatus?
  lostReason        LostReason?
  // Module K — retainer renewal tracking
  contractStartDate DateTime?
  contractEndDate   DateTime?
  nextRenewalDate   DateTime?
  autoRenewal       Boolean        @default(false)
  renewalStatus     RenewalStatus?
  renewalNotes      String?        @db.Text
  // Lead-owned contact identity (a lead can exist before a Client is created at OUTREACH)
  contactName       String?
  companyName       String?
  companySize       String?      // '1-10' | '11-100' | '101-500' | '501-1000' | '1000+'
  contactEmail      String?      // brief: email
  contactPhone      String?      // brief: mobile (unique per organization, enforced in app)
  landlinePhone     String?
  jobTitle          String?      // brief: designation
  linkedinUrl       String?
  linkedinChecked   Boolean      @default(false)
  linkedinFound     Boolean?
  // Address
  address           String?
  city              String?
  state             String?
  zip               String?
  country           String?      @default("India")
  // Billing (used to auto-fill quotations / proforma invoices)
  billingAddress    String?      @db.Text
  gstNumber         String?
  // Company digital presence
  website           String?
  instagramHandle   String?
  facebookPage      String?
  industry          String?
  // Engagement tracking
  lastContactedDate DateTime?
  // LinkedIn Intelligence dossier (Module A)
  dossierJson        Json?
  dossierStatus      String?     // 'pending' | 'complete' | 'failed'
  dossierGeneratedAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // SetNull (not Cascade): deleting a client must NOT wipe the originating lead and
  // its stage history / deal fields — the CRM conversion audit trail is preserved.
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo        User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  stageHistory      StageHistory[]
  dealFields        DealField[]
  activities        Activity[]   @relation("LeadActivities")
  tasks             Task[]       @relation("LeadTasks")
  notes             Note[]
  contacts          LeadContact[]

  @@unique([organizationId, leadId])
  @@index([organizationId, stage])
  @@index([organizationId, contactPhone])
  @@map("leads")
}

// Module G — secondary stakeholders on a lead (not separate leads). Each can carry its
// own LinkedIn Intelligence dossier independent of the lead-level one.
model LeadContact {
  id                 String      @id @default(cuid())
  leadId             String
  name               String
  designation        String?
  email              String?
  phone              String?
  linkedinUrl        String?
  role               ContactRole
  notes              String?     @db.Text
  dossierJson        Json?
  dossierStatus      String?     // 'pending' | 'complete' | 'failed'
  dossierGeneratedAt DateTime?
  createdAt          DateTime    @default(now())

  lead               Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_contacts")
}

// Monotonic counter for human-readable Lead IDs (FL-YYYYMM-XXXXXX), per org per month.
model LeadIdCounter {
  id             String @id @default(cuid())
  organizationId String
  yearMonth      String // 'YYYYMM'
  counter        Int    @default(0)

  @@unique([organizationId, yearMonth])
  @@map("lead_id_counters")
}

// Generic sequential counter for document numbers (QT / PI / INV), per org, per scope, per period (year).
model DocCounter {
  id             String @id @default(cuid())
  organizationId String
  scope          String // 'QT' | 'PI' | 'INV'
  period         String // 'YYYY'
  counter        Int    @default(0)

  @@unique([organizationId, scope, period])
  @@map("doc_counters")
}

// ── Module C: Quotation / Proforma Invoice ─────────────────────────────────────
enum DocumentType {
  QUOTATION
  PROFORMA_INVOICE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  CANCELLED
}

model QuoteDocument {
  id               String       @id @default(cuid())
  organizationId   String
  documentType     DocumentType
  documentNumber   String       // EL/QT/YYYY/NNN or EL/PI/YYYY/NNN (unique PER ORG)
  documentDate     DateTime     @default(now())
  expirationDate   DateTime
  clientId         String       // FK -> Client.id (quotes are raised for clients-page clients)
  clientName       String       // denormalized for display
  contactPerson    String
  clientEmail      String?
  clientPhone      String?
  billingAddress   String?
  clientState      String?      // drives CGST/SGST vs IGST at generation time
  paymentTerms     String
  customerRef      String?
  salespersonId    String?
  salesTeam        String?
  onlineSignature  Boolean      @default(false)
  onlinePayment    Boolean      @default(false)
  tags             String[]     @default([])
  paymentMethod    String?
  clientGst        String?
  projectStartDate DateTime?
  deliveryDate     DateTime?
  projectNotes     String?      @db.Text
  scope            String?      @db.Text
  termsConditions  String       @db.Text
  status           QuoteStatus  @default(DRAFT)
  // Snapshot of computed totals at save time (server-authoritative).
  untaxedAmount    Decimal      @default(0)
  totalDiscount    Decimal      @default(0)
  cgst             Decimal      @default(0)
  sgst             Decimal      @default(0)
  igst             Decimal      @default(0)
  totalTax         Decimal      @default(0)
  grandTotal       Decimal      @default(0)
  amountInWords    String?
  pdfUrl           String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  lineItems        QuoteLineItem[]
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client       @relation(fields: [clientId], references: [id])
  salesperson      User?        @relation("QuoteSalesperson", fields: [salespersonId], references: [id])
  invoiceDraft     InvoiceDraft?

  @@unique([organizationId, documentNumber])
  @@index([clientId])
  @@index([organizationId, status])
  @@map("quote_documents")
}

model QuoteLineItem {
  id          String        @id @default(cuid())
  quoteId     String
  sortOrder   Int
  description String
  unit        String        // Hours | Days | Months | Units | Lump Sum
  quantity    Decimal
  unitPrice   Decimal
  discountPct Decimal       @default(0)
  taxType     String        @default("IGST_S") // tax type code (drives the GST split)
  taxPct      Decimal       @default(18)         // editable rate %
  amount      Decimal       // (qty * price) * (1 - disc%)

  quote       QuoteDocument @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_line_items")
}

model StageHistory {
  id          String    @id @default(cuid())
  leadId      String
  fromStage   LeadStage
  toStage     LeadStage
  notes       String?
  changedById String
  changedAt   DateTime  @default(now())

  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changedBy   User      @relation("StageChanger", fields: [changedById], references: [id])

  @@index([leadId])
  @@map("stage_history")
}

model DealField {
  id         String   @id @default(cuid())
  leadId     String
  fieldKey   String
  fieldValue String?
  updatedAt  DateTime @updatedAt

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, fieldKey])
  @@map("deal_fields")
}

// ──────────────────────────────────────────────
// WORKFLOW AUTOMATION
// ──────────────────────────────────────────────

enum WorkflowTrigger {
  TASK_STATUS_CHANGE
  TASK_ASSIGNED
  TASK_DEADLINE_APPROACHING
  TASK_OVERDUE
  TASK_CREATED
  PROJECT_STATUS_CHANGE
}

enum WorkflowAction {
  NOTIFY
  EMAIL
  NOTIFY_AND_EMAIL
  CHANGE_TASK_STATUS
  REASSIGN_TASK
}

model WorkflowRule {
  id             String          @id @default(cuid())
  name           String
  trigger        WorkflowTrigger
  condition      Json            @default("{}")
  action         WorkflowAction  @default(NOTIFY)
  targets        String[]        @default([])
  isActive       Boolean         @default(true)
  organizationId String
  creatorId      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  creator        User            @relation("WorkflowCreator", fields: [creatorId], references: [id])

  @@index([organizationId, isActive])
  @@map("workflow_rules")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  action         String   // e.g., "CREATE", "UPDATE", "DELETE", "ARCHIVE"
  entityType     String   // e.g., "USER", "LEAD", "CLIENT", "PROJECT"
  entityId       String
  details        Json?    // Stores specific changes
  createdAt      DateTime @default(now())

  user         User         @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationAuditLogs", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("audit_logs")
}


// -- §5 Revenue Module ----------------------------------------------------------

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum ExpenseCategory {
  VENDOR
  TRAVEL
  EQUIPMENT
  MARKETING
  MISC
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

model InvoiceDraft {
  id             String        @id @default(cuid())
  organizationId String
  quoteId        String        @unique
  draftNumber    String        // unique PER ORG
  clientId       String
  clientName     String
  status         InvoiceStatus @default(DRAFT)
  lineItems      Json
  untaxedAmount  Decimal       @default(0)
  cgst           Decimal       @default(0)
  sgst           Decimal       @default(0)
  igst           Decimal       @default(0)
  totalTax       Decimal       @default(0)
  grandTotal     Decimal
  notes          String?       @db.Text
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote          QuoteDocument @relation(fields: [quoteId], references: [id])
  client         Client        @relation("ClientInvoiceDrafts", fields: [clientId], references: [id])

  @@unique([organizationId, draftNumber])
  @@index([organizationId])
  @@map("invoice_drafts")
}

model Contract {
  id               String         @id @default(cuid())
  organizationId   String
  clientId         String
  title            String
  value            Decimal
  advanceAmount    Decimal?
  advanceReceived  Boolean        @default(false)
  cgst             Decimal        @default(0)
  sgst             Decimal        @default(0)
  igst             Decimal        @default(0)
  totalTax         Decimal        @default(0)
  billingFrequency String
  startDate        DateTime
  endDate          DateTime?
  status           ContractStatus @default(ACTIVE)
  notes            String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client         @relation("ClientContracts", fields: [clientId], references: [id])
  payments         Payment[]
  subscriptions    Subscription[]

  @@index([organizationId])
  @@map("contracts")
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String
  contractId     String?
  amount         Decimal
  paidOn         DateTime
  method         String?
  reference      String?
  notes          String?
  status         PaymentStatus @default(PAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client        @relation("ClientPayments", fields: [clientId], references: [id])
  contract       Contract?     @relation(fields: [contractId], references: [id])

  @@index([clientId])
  @@index([organizationId])
  @@map("payments")
}

model Subscription {
  id               String             @id @default(cuid())
  organizationId   String
  clientId         String
  contractId       String?
  amount           Decimal
  taxIncluded      Boolean            @default(false)
  billingFrequency String
  startDate        DateTime
  nextBillingDate  DateTime?
  status           SubscriptionStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client             @relation("ClientSubscriptions", fields: [clientId], references: [id])
  contract         Contract?          @relation(fields: [contractId], references: [id])

  @@index([organizationId])
  @@map("subscriptions")
}

model Expense {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String?
  clientId       String?
  vendor         String
  category       ExpenseCategory @default(MISC)
  amount         Decimal
  date           DateTime
  description    String?
  receiptUrl     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?        @relation("ProjectExpenses", fields: [projectId], references: [id])
  client         Client?         @relation("ClientExpenses", fields: [clientId], references: [id])

  @@index([projectId])
  @@index([organizationId])
  @@map("expenses")
}
