{
  "name": "flowzen",
  "version": "1.0.0",
  "private": true,
  "description": "Flowzen — Premium Agency Project Management Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "npm run generate --workspace=apps/api",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api",
    "db:studio": "npm run studio --workspace=apps/api",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=apps/web"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
